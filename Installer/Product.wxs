<?xml version="1.0" encoding="UTF-8"?>
<!--
  VectraConnect WiX Installer
  Builds: VectraConnect_Setup.exe (bootstrapper) wrapping VectraConnect.msi
  Requires: WiX Toolset v3.11+ (https://wixtoolset.org)
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:netfx="http://schemas.microsoft.com/wix/NetFxExtension"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">

  <Product Id="*"
           Name="Vectra Connect"
           Language="1033"
           Version="1.0.0.0"
           Manufacturer="Your Organisation"
           UpgradeCode="B7C8D9E0-F1A2-3456-BCDE-F01234567890">

    <Package InstallerVersion="500"
             Compressed="yes"
             InstallScope="perUser"
             Description="Publishes MS Project schema to Excel/CSV via a ribbon button"
             Comments="VSTO add-in for Microsoft Project" />

    <!-- ── Upgrade handling: remove old version before installing new ── -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of Vectra Connect is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- ── Properties ──────────────────────────────────────────────── -->
    <Property Id="ARPPRODUCTICON"   Value="PublisherIcon.ico" />
    <Property Id="ARPHELPLINK"      Value="https://your-org.example.com/vectra-connect" />
    <Property Id="ARPURLINFOABOUT"  Value="https://your-org.example.com" />
    <Property Id="ARPNOREPAIR"      Value="1" />   <!-- hide Repair button -->

    <!-- Detect installed MS Project (any version 14+) -->
    <Property Id="MSPROJECTINSTALLED">
      <RegistrySearch Id="SearchMSProject14" Type="raw" Root="HKLM"
                      Key="SOFTWARE\Microsoft\Office\14.0\MS Project\InstallRoot" Name="Path" />
      <RegistrySearch Id="SearchMSProject15" Type="raw" Root="HKLM"
                      Key="SOFTWARE\Microsoft\Office\15.0\MS Project\InstallRoot" Name="Path" />
      <RegistrySearch Id="SearchMSProject16" Type="raw" Root="HKLM"
                      Key="SOFTWARE\Microsoft\Office\16.0\MS Project\InstallRoot" Name="Path" />
    </Property>

    <!-- Detect .NET Framework 4.8 -->
    <PropertyRef Id="NETFRAMEWORK48" />

    <!-- ── Launch conditions ────────────────────────────────────────── -->
    <Condition Message="This add-in requires Microsoft Project 2016, 2019, 2021 or Microsoft 365 (desktop). Please install Microsoft Project first.">
      <![CDATA[Installed OR MSPROJECTINSTALLED]]>
    </Condition>

    <Condition Message="This add-in requires .NET Framework 4.8 or later. The installer will install it automatically — please re-run the installer if this message appears.">
      <![CDATA[Installed OR NETFRAMEWORK48]]>
    </Condition>

    <!-- ── Directory structure ──────────────────────────────────────── -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="LocalAppDataFolder">
        <Directory Id="INSTALLFOLDER" Name="VectraConnect">
          <!-- All add-in files land here: %LOCALAPPDATA%\VectraConnect\ -->
        </Directory>
      </Directory>
    </Directory>

    <!-- ── Components ───────────────────────────────────────────────── -->
    <ComponentGroup Id="AddInFiles" Directory="INSTALLFOLDER">

      <!-- Core add-in DLL -->
      <Component Id="cmpAddInDll" Guid="C1D2E3F4-A5B6-7890-CDEF-012345678901">
        <File Id="VectraConnectDll"
              Source="$(var.VectraConnect.TargetPath)"
              KeyPath="yes" />
      </Component>

      <!-- Add-in manifest (.vsto) -->
      <Component Id="cmpVstoManifest" Guid="D2E3F4A5-B6C7-8901-DEF0-123456789012">
        <File Id="VectraConnectVsto"
              Source="$(var.VectraConnect.TargetPath).vsto"
              KeyPath="yes" />
      </Component>

      <!-- ClickOnce application manifest -->
      <Component Id="cmpAppManifest" Guid="E3F4A5B6-C7D8-9012-EF01-234567890123">
        <File Id="VectraConnectManifest"
              Source="$(var.VectraConnect.TargetDir)VectraConnect.dll.manifest"
              KeyPath="yes" />
      </Component>

      <!-- ClosedXML dependency -->
      <Component Id="cmpClosedXml" Guid="F4A5B6C7-D8E9-0123-F012-345678901234">
        <File Id="ClosedXmlDll"
              Source="$(var.VectraConnect.TargetDir)ClosedXML.dll"
              KeyPath="yes" />
      </Component>

      <!-- ExcelNumberFormat (ClosedXML dep) -->
      <Component Id="cmpExcelNumberFormat" Guid="A5B6C7D8-E9F0-1234-0123-456789012345">
        <File Id="ExcelNumberFormatDll"
              Source="$(var.VectraConnect.TargetDir)ExcelNumberFormat.dll"
              KeyPath="yes" />
      </Component>

      <!-- DocumentFormat.OpenXml (ClosedXML dep) -->
      <Component Id="cmpOpenXml" Guid="B6C7D8E9-F0A1-2345-1234-567890123456">
        <File Id="OpenXmlDll"
              Source="$(var.VectraConnect.TargetDir)DocumentFormat.OpenXml.dll"
              KeyPath="yes" />
      </Component>

      <!-- VSTO registry registration (per-user, no admin needed) -->
      <Component Id="cmpVstoRegistry" Guid="C7D8E9F0-A1B2-3456-2345-678901234567">
        <KeyPath Id="kpVstoReg" />
        <!-- Register the add-in with MS Project -->
        <RegistryKey Root="HKCU"
                     Key="Software\Microsoft\Office\MS Project\AddIns\VectraConnect">
          <RegistryValue Type="string"  Name="Description"  Value="Vectra Connect" />
          <RegistryValue Type="string"  Name="FriendlyName" Value="Vectra Connect" />
          <RegistryValue Type="integer" Name="LoadBehavior" Value="3" />
          <RegistryValue Type="string"  Name="Manifest"
                         Value="[INSTALLFOLDER]VectraConnect.vsto|vstolocal" />
        </RegistryKey>
      </Component>

    </ComponentGroup>

    <!-- ── Features ─────────────────────────────────────────────────── -->
    <Feature Id="ProductFeature"
             Title="Vectra Connect"
             Description="Adds a Publish Schema button to the MS Project ribbon."
             Level="1">
      <ComponentGroupRef Id="AddInFiles" />
    </Feature>

    <!-- ── UI: wizard with custom banner ────────────────────────────── -->
    <UIRef Id="WixUI_InstallDir" />

    <!-- Skip the folder picker — we always install to %LOCALAPPDATA%\VectraConnect -->
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    <WixVariable Id="WixUIBannerBmp"  Value="Assets\banner.bmp"  />   <!-- 493×58  px -->
    <WixVariable Id="WixUIDialogBmp"  Value="Assets\dialog.bmp"  />   <!-- 493×312 px -->
    <WixVariable Id="WixUILicenseRtf" Value="Assets\license.rtf" />

    <!-- Icon shown in Add/Remove Programs -->
    <Icon Id="PublisherIcon.ico" SourceFile="Assets\publisher.ico" />

  </Product>
</Wix>
